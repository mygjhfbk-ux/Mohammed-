# .env.example
# Copy this file to .env and fill values. Do NOT commit secrets.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service role key ONLY needed for running migrations or server-side functions (DO NOT put in client apps)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional bucket for storage
SUPABASE_STORAGE_BUCKET=public
